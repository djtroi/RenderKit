diff --git a/.github/workflows/cross-platform-storage.yml b/.github/workflows/cross-platform-storage.yml
new file mode 100644
index 0000000000000000000000000000000000000000..3a5d2f48e95b20c00509f5461bf5c63d5371594c
--- /dev/null
+++ b/.github/workflows/cross-platform-storage.yml
@@ -0,0 +1,69 @@
+name: Cross-Platform Foundation
+
+on:
+  push:
+    branches: '*'
+  pull_request:
+    branches: '*'
+
+permissions:
+  contents: read
+
+jobs:
+  foundation-tests:
+    name: Foundation / ${{ matrix.os }}
+    runs-on: ${{ matrix.os }}
+    strategy:
+      fail-fast: false
+      matrix:
+        os:
+          - windows-latest
+          - ubuntu-latest
+          - macos-latest
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v6
+
+      - name: Install Pester
+        shell: pwsh
+        run: |
+          Set-PSRepository -Name PSGallery -InstallationPolicy Trusted
+          Install-Module Pester -MinimumVersion 5.5.0 -Scope CurrentUser -Force
+
+      - name: Run foundation tests
+        shell: pwsh
+        run: |
+          Import-Module Pester -MinimumVersion 5.5.0
+          $result = Invoke-Pester `
+            -Path ./Tests/Storage, ./Tests/Versioning `
+            -PassThru
+          if ($result.FailedCount -gt 0) {
+              throw "$($result.FailedCount) foundation test(s) failed."
+          }
+
+  windows-powershell-5:
+    name: Foundation / Windows PowerShell 5.1
+    runs-on: windows-latest
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v6
+
+      - name: Install Pester
+        shell: powershell
+        run: |
+          [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
+          Set-PSRepository -Name PSGallery -InstallationPolicy Trusted
+          Install-Module Pester -MinimumVersion 5.5.0 -Scope CurrentUser -Force
+
+      - name: Run foundation tests
+        shell: powershell
+        run: |
+          Import-Module Pester -MinimumVersion 5.5.0
+          $result = Invoke-Pester `
+            -Path ./Tests/Storage, ./Tests/Versioning `
+            -PassThru
+          if ($result.FailedCount -gt 0) {
+              throw "$($result.FailedCount) foundation test(s) failed."
+          }
