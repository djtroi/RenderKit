      "adapters": ["MediaInfo", "ExifTool", "XMP"]
    },
    {
      "mediaKind": "Audio",
      "extensions": [".wav", ".wave", ".bwf", ".rf64"],
      "mimeTypes": ["audio/wav", "audio/x-wav"],
      "adapters": ["MediaInfo", "ExifTool", "BWF", "iXML", "XMP"]
    },
    {
      "mediaKind": "Audio",
      "extensions": [".mp3"],
      "mimeTypes": ["audio/mpeg"],
      "adapters": ["MediaInfo", "ExifTool", "ID3"]
    },
    {
      "mediaKind": "Audio",
      "extensions": [".m4a", ".aac", ".aif", ".aiff", ".flac", ".ogg", ".wma"],
      "mimeTypes": ["audio/mp4", "audio/aac", "audio/aiff", "audio/flac", "audio/ogg"],
      "adapters": ["MediaInfo", "ExifTool", "XMP", "DublinCoreXmp"]
    },
    {
      "mediaKind": "Image",
      "extensions": [".jpg", ".jpeg", ".tif", ".tiff", ".dng", ".raw", ".cr2", ".cr3", ".nef", ".arw", ".orf", ".raf", ".rw2"],
      "mimeTypes": ["image/jpeg", "image/tiff", "image/x-adobe-dng"],
      "adapters": ["ExifTool", "IPTC", "XMP", "DublinCoreXmp", "MediaInfo"]
    },
    {
      "mediaKind": "Image",
      "extensions": [".png", ".webp", ".heic", ".heif", ".avif", ".gif", ".bmp", ".psd", ".psb", ".exr", ".svg", ".ico"],
      "mimeTypes": ["image/png", "image/webp", "image/heic", "image/heif", "image/avif", "image/gif", "image/bmp", "image/svg+xml"],
      "adapters": ["ExifTool", "XMP", "DublinCoreXmp", "MediaInfo"]
    }
  ],
  "fallbackAdapters": ["ExifTool", "MediaInfo"]
}
