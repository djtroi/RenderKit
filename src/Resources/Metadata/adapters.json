  "routes": [
    {
      "mediaKind": "Video",
      "extensions": [".mov", ".qt"],
      "mimeTypes": ["video/quicktime"],
      "adapters": ["MediaInfo", "ExifTool", "XMP", "DublinCoreXmp"]
    },
    {
      "mediaKind": "Video",
      "extensions": [".mp4", ".m4v"],
      "mimeTypes": ["video/mp4"],
      "adapters": ["MediaInfo", "ExifTool", "XMP", "DublinCoreXmp"]
    },
    {
      "mediaKind": "Video",
      "extensions": [".mkv", ".webm"],
      "mimeTypes": ["video/x-matroska", "video/webm"],
      "adapters": ["MediaInfo", "Matroska", "ExifTool", "XMP"]
    },
    {
      "mediaKind": "Video",
      "extensions": [".mxf", ".avi", ".wmv", ".m2ts", ".mts"],
      "mimeTypes": ["application/mxf", "video/x-msvideo", "video/x-ms-wmv"],
      "adapters": ["MediaInfo", "ExifTool", "XMP"]
    },
    {
      "mediaKind": "Video",
      "extensions": [".r3d", ".braw"],
